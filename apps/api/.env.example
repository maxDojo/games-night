# --- Server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Neon Postgres in prod, local Postgres in dev) ---
DATABASE_URL="postgresql://user:password@localhost:5432/games_night?schema=public"

# --- Auth ---
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN=7d

# --- CORS (comma-separated origins; * to allow all in dev) ---
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"

# --- Realtime ---
SOCKET_PATH=/socket.io

# --- Feature flags ---
ENABLE_SWAGGER=true

# --- Providers ---
# Free defaults for development. See README §Providers for the full table
# (incl. paid/upgrade options) and where to add new providers.

# Trivia content source.
#   open-trivia-db  free, public (default)
#   none            no remote fetch; relies on existing DB content
TRIVIA_PROVIDER=open-trivia-db

# AI generation (themed packs, content gen).
#   disabled        no AI calls (default — keeps you on the $0 path)
#   (future)        anthropic | openai | ollama — add the impl then update the env enum
AI_PROVIDER=disabled

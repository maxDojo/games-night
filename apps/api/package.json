{
  "name": "@games-night/api",
  "version": "0.1.0",
  "description": "Backend API for Games Night (trivia, charades, taboo, custom games).",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prompts": "tsx prisma/seed.ts --prompts-only",
    "db:seed:offline": "tsx prisma/seed.ts --skip-trivia",
    "openapi:json": "tsx scripts/generate-openapi.ts",
    "api-client:generate": "pnpm openapi:json && openapi-typescript generated/openapi.json -o generated/api-types.d.ts",
    "api-client:check": "pnpm api-client:generate && tsc -p tsconfig.api-client.json",
    "smoke:docs": "tsx scripts/smoke-docs.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/client": "^5.18.0",
    "argon2": "^0.40.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^2.1.0",
    "nanoid": "^5.0.7",
    "pino-pretty": "^11.2.2",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
